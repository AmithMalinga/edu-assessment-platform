generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String   @unique
  age             Int
  educationalLevel String  // Grade 1, 2, 3, ... 12, 13
  password        String
  role            Role     @default(STUDENT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attempts        Attempt[]

  @@map("users")
}

enum Role {
  STUDENT
  ADMIN
}

model Exam {
  id          String   @id @default(uuid())
  title       String
  description String?
  duration    Int      // Duration in minutes
  passingScore Int
  attempts    Attempt[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attempt {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  score     Int
  timeTaken Int      // Time taken in seconds
  completedAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  content   String
  rating    Int
  avatar    String?
  createdAt DateTime @default(now())
}

model Grade {
  id        Int      @id
  name      String
  subjects  Subject[]
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  gradeId   Int
  grade     Grade    @relation(fields: [gradeId], references: [id])
  questions Question[]
}

enum QuestionType {
  MCQ
  STRUCTURED
  ESSAY
}

model Question {
  id            String   @id @default(uuid())
  content       String
  type          QuestionType
  images        String[]
  choices       String[]
  correctAnswer String?
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
