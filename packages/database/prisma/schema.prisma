generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String   @unique
  age             Int
  educationalLevel String  // Grade 1, 2, 3, ... 12, 13
  password        String
  role            Role     @default(STUDENT)
  username        String?  @unique
  requiresPasswordChange Boolean @default(false)
  // Tutor-specific fields
  subject         String?
  studentCount    StudentCountRange?
  bio             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attempts        Attempt[]
  tutorRegistration TutorRegistration?

  @@map("users")
}

enum Role {
  STUDENT
  ADMIN

  TUTOR
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StudentCountRange {
  ZERO_FIFTY           // 0-50
  FIFTY_FIVE_HUNDRED   // 50-500
  FIVE_HUNDRED_PLUS    // 500+
}
model Exam {
  id            String         @id @default(uuid())
  title         String
  description   String?
  duration      Int            // Duration in minutes
  passingScore  Int
  attempts      Attempt[]
  examQuestions ExamQuestion[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ExamQuestion {
  id         String   @id @default(uuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int
  marks      Int      @default(1)

  @@unique([examId, questionId])
}

model Attempt {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  score       Int
  timeTaken   Int      // Time taken in seconds
  answers     Json?    // { questionId: selectedAnswer }
  completedAt DateTime @default(now())
}

model TutorRegistration {
  id             String             @id @default(uuid())
  name           String
  email          String             @unique
  phone          String
  subject        String
  studentCount   StudentCountRange
  username       String             @unique
  agreedToTerms  Boolean
  status         RegistrationStatus @default(PENDING)
  rejectionReason String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         String?            @unique

  @@map("tutor_registrations")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  content   String
  rating    Int
  avatar    String?
  createdAt DateTime @default(now())
}

model Grade {
  id        Int      @id
  name      String
  subjects  Subject[]
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  gradeId   Int
  grade     Grade    @relation(fields: [gradeId], references: [id])
  questions Question[]
}

enum QuestionType {
  MCQ
  STRUCTURED
  ESSAY
}

model Question {
  id            String         @id @default(uuid())
  content       String
  type          QuestionType
  lesson        String         @default("General")
  images        String[]
  choices       String[]
  correctAnswer String?
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id])
  examQuestions ExamQuestion[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
